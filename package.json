{
  "name": "openclawdreams",
  "version": "2.3.3",
  "description": "A reflection engine that synthesizes agent-operator interactions into dreams",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openclawdreams": "dist/bin/openclawdreams.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/openclawdreams.js",
    "test": "node --import tsx --test --test-isolation=process --test-concurrency=1 'test/**/*.test.ts'",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts' 'bin/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts' 'test/**/*.ts' 'bin/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' 'bin/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts' 'bin/**/*.ts'",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "release:first": "standard-version --first-release"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "openclaw",
    "dreams",
    "memory",
    "reflection"
  ],
  "files": [
    "dist/src",
    "dist/bin",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "openclaw.plugin.json",
    "skills"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RogueCtrl/OpenClawDreams.git"
  },
  "homepage": "https://github.com/RogueCtrl/OpenClawDreams#readme",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.4.1",
    "commander": "^14.0.3",
    "dotenv": "^17.2.4",
    "p-retry": "^7.1.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.2.3",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "standard-version": "^9.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {
    "openclaw": ">=1.0.0"
  },
  "openclaw": {
    "id": "openclawdreams",
    "extensions": [
      "./dist/src/index.js"
    ]
  }
}
